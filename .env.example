# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://ticketing:change-me@localhost:5432/it_ticketing
DB_PASSWORD=change-me

# Auth (JWT_SECRET_KEY must be set and >= 32 chars for production)
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
COOKIE_SECURE=false
ADMIN_DEFAULT_PASSWORD=change-me-in-production

# Rate limiting
RATE_LIMIT_LOGIN_PER_MINUTE=10

# SMTP (Notifications — optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
NOTIFICATION_FROM_EMAIL=noreply@example.com

# Webhook (Notifications — optional, comma-separated URLs)
WEBHOOK_URLS=

# Attachments
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.png,.jpg,.jpeg,.gif,.zip

# SLA Hours
SLA_HOURS_URGENT=4
SLA_HOURS_HIGH=8
SLA_HOURS_MEDIUM=24
SLA_HOURS_LOW=48

# App
APP_PORT=8000
WORKERS=2
DEBUG=false
