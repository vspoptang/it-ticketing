1|# Database (PostgreSQL)
2|DATABASE_URL=postgresql+asyncpg://ticketing:change-me@localhost:5432/it_ticketing
3|DB_PASSWORD=change-me
4|
5|# Auth (JWT_SECRET_KEY must be set and >= 32 chars for production)
6|JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
7|JWT_ALGORITHM=HS256
8|JWT_EXPIRATION_HOURS=24
9|COOKIE_SECURE=false
10|ADMIN_DEFAULT_PASSWORD=change-me-in-production
11|
12|# Rate limiting
13|RATE_LIMIT_LOGIN_PER_MINUTE=10
14|
15|# SMTP (Notifications — optional)
16|SMTP_HOST=
17|SMTP_PORT=587
18|SMTP_USER=
19|SMTP_PASSWORD=
20|SMTP_USE_TLS=true
21|NOTIFICATION_FROM_EMAIL=noreply@example.com
22|
23|# Webhook (Notifications — optional, comma-separated URLs)
24|WEBHOOK_URLS=
25|
26|# Attachments
27|UPLOAD_DIR=app/static/uploads
28|MAX_UPLOAD_SIZE_MB=10
29|ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.png,.jpg,.jpeg,.gif,.zip
30|
31|# SLA Hours
32|SLA_HOURS_URGENT=1
33|SLA_HOURS_HIGH=2
34|SLA_HOURS_MEDIUM=4
35|SLA_HOURS_LOW=8
36|
37|# App
38|APP_PORT=8000
39|WORKERS=2
40|DEBUG=false
41|